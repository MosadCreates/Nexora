# Environment Variables Template
# Copy this to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini AI
GEMINI_API_KEY=

# Polar.sh Payments
POLAR_ORGANIZATION_TOKEN=
POLAR_WEBHOOK_SECRET=
NEXT_PUBLIC_POLAR_STARTER_MONTHLY_ID=
NEXT_PUBLIC_POLAR_STARTER_YEARLY_ID=
NEXT_PUBLIC_POLAR_PROFESSIONAL_MONTHLY_ID=
NEXT_PUBLIC_POLAR_PROFESSIONAL_YEARLY_ID=

# Upstash Redis (for rate limiting + caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (error tracking)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# App URL (Fix #3 Audit 2: open redirect validation)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Cloudflare Turnstile (Fix #10 Audit 2: brute-force protection)
# Get free keys at: dash.cloudflare.com → Turnstile → Add Site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Health check admin key (Fix #12 Audit 2: protect detailed diagnostics)
HEALTH_CHECK_SECRET=

# IndexNow key for instant search indexing
INDEXNOW_KEY=

MAINTENANCE_MODE=false
